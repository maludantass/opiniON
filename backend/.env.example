# Configurações do Servidor
PORT=3000

# Configurações do Banco de Dados PostgreSQL
DB_USER=postgres
DB_HOST=localhost
DB_NAME=opinion
DB_PASSWORD=sua_senha_aqui
DB_PORT=5432

# Auth (JWT + bcrypt)
JWT_SECRET=gere_um_segredo_longo_em_producao
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Sequelize (dev): cria/atualiza tabela users automaticamente quando não está em production
NODE_ENV=development
